{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'our_places_rs'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=our_places_rs",
                    "--package=our_places_rs"
                ],
                "filter": {
                    "name": "our_places_rs",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'our_places_rs'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=our_places_rs",
                    "--package=our_places_rs"
                ],
                "filter": {
                    "name": "our_places_rs",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug integration test 'integration_tests'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--test=integration_tests",
                    "--package=our_places_rs"
                ],
                "filter": {
                    "name": "integration_tests",
                    "kind": "test"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Web_app Next.js: debug server-side",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}/web_app",
            "request": "launch",
            "command": "npm run dev"
        },
        {
            "name": "Web_app Next.js: debug client-side",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000"
        },
        {
            "name": "Web_app Next.js: debug full stack",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}/web_app",
            "command": "npm run dev",
            "serverReadyAction": {
                "pattern": "started server on .+, url: (https?://.+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        }
    ]
}